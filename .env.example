# Copy this file to .env and replace with your real values
# cp .env.example .env

# Shared JWT secret for user-service and api-gateway
AUTH_JWT_SECRET=replace-with-a-long-random-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-service-token

# User service bootstrap admin (recommended to load from secret manager in real env)
BOOTSTRAP_ADMIN_NAME="Super Admin"
BOOTSTRAP_ADMIN_EMAIL=admin@ems.com
BOOTSTRAP_ADMIN_PASSWORD=Admin@123!
JWT_EXPIRES_MINUTES=120
JWT_REFRESH_EXPIRES_MINUTES=10080
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_ATTEMPT_WINDOW_SECONDS=900
AUTH_LOCKOUT_SECONDS=900

# Database passwords used by compose services
USER_DB_PASSWORD=replace-user-db-password
PRODUCT_DB_PASSWORD=replace-product-db-password
ORDER_DB_PASSWORD=replace-order-db-password
INVENTORY_DB_PASSWORD=replace-inventory-db-password
PAYMENT_DB_PASSWORD=replace-payment-db-password

# Grafana admin credentials
GRAFANA_ADMIN_USER=replace-grafana-admin-user
GRAFANA_ADMIN_PASSWORD=replace-grafana-admin-password

# Payment behavior
PAYMENT_FAILURE_PROBABILITY=0.0
PAYMENT_DELAY_MS=250

# Saga retry/circuit breaker tuning
HTTP_CONNECT_TIMEOUT_MS=2000
HTTP_READ_TIMEOUT_MS=5000
SAGA_RETRY_MAX_ATTEMPTS=3
SAGA_RETRY_INITIAL_BACKOFF_MS=250
SAGA_CB_FAILURE_THRESHOLD=3
SAGA_CB_OPEN_DURATION_MS=4000

# Chaos mode
CHAOS_MODE=false
LATENCY_PROBABILITY=0.0
ERROR_PROBABILITY=0.0
CHAOS_DELAY_MS=0
